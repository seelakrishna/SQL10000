use company_db;

SELECT EMP_NAME,SALARY
FROM EMPLOYEES
WHERE SALARY>40000;

SELECT EMP_NAME, CITY
FROM EMPLOYEES
WHERE EMP_NAME LIKE 'a%';

SELECT EMP_NAME,DEPARTMENT
FROM EMPLOYEES
WHERE DEPARTMENT  IN ('HR', 'FINANCE');

SELECT EMP_NAME,DEPARTMENT
FROM EMPLOYEES
WHERE DEPARTMENT IS  NULL;

SELECT COUNT(*)
FROM EMPLOYEES
WHERE SALARY>30000;

select AVG(SALARY)
FROM EMPLOYEES
WHERE  DEPARTMENT='IT';
